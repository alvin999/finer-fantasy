---
import Layout from "../layouts/Layout.astro";
import { PuckSimulationD3 } from "../components/PuckSimulationD3";
import Footer from "../components/Footer.astro";
import "../styles.css";
---

<Layout title="WD 值與壓力曲線教學 - Finer Fantasy">
    <header>
        <div class="header-text">
            <h1>Finer Fantasy</h1>
            <p>Water Debit · Puck Resistance · Extraction Pressure</p>
        </div>
        <div class="machine-tabs">
            <button
                class="machine-tab active"
                onclick="switchMachine('rotary', this)">Rotary Pump</button
            >
            <button class="machine-tab" onclick="switchMachine('vibe', this)"
                >Vibration Pump</button
            >
            <a
                href="/finer-fantasy/learning"
                class="machine-tab highlight-tab"
                style="text-decoration:none;">粉餅阻力 (學習導覽)</a
            >
        </div>
    </header>

    <div class="main">
        <!-- ===== LEFT PANEL ===== -->
        <div class="panel">
            <div id="panel-rv">
                <div class="panel-section">
                    <div class="section-label">WD 值 — Water Debit</div>
                    <div>
                        <div class="slider-header">
                            <span class="slider-name">10 秒出水量</span>
                            <span
                                ><span class="slider-value" id="wd-display"
                                    >80</span
                                ><span class="slider-unit"> g/10s</span></span
                            >
                        </div>
                        <input
                            type="range"
                            id="wd-slider"
                            min="60"
                            max="100"
                            step="1"
                            value="80"
                        />
                        <div class="slider-hints">
                            <span>60 低</span><span>80 一般</span><span
                                >100 高</span
                            >
                        </div>
                    </div>
                </div>
                <div class="panel-section" style="margin-top:4px;">
                    <div class="section-label">Headspace — 粉頂空間</div>
                    <div>
                        <div class="slider-header">
                            <span class="slider-name">預留高度</span>
                            <span
                                ><span class="slider-value" id="hs-display"
                                    >2.0</span
                                ><span class="slider-unit"> mm</span></span
                            >
                        </div>
                        <input
                            type="range"
                            id="hs-slider"
                            min="1"
                            max="5"
                            step="0.5"
                            value="2"
                        />
                        <div class="slider-hints">
                            <span>1mm 緊湊</span><span>2mm 標準</span><span
                                >5mm 過大</span
                            >
                        </div>
                    </div>
                </div>

                <div class="panel-section" style="margin-top:4px;">
                    <div class="section-label">佈粉 / 填壓手法</div>
                    <div class="toggle-group" id="rv-methods">
                        <button
                            class="toggle-btn active"
                            onclick="setMethod('normal', this)"
                            >標準（WDT + 輕填壓）</button
                        >
                        <button
                            class="toggle-btn"
                            onclick="setMethod('heavy', this)">重填壓</button
                        >
                        <button
                            class="toggle-btn"
                            onclick="setMethod('uneven', this)"
                            >佈粉不均（偏流）</button
                        >
                    </div>
                </div>

                <div class="panel-section" style="margin-top:4px;">
                    <div class="section-label">動畫控制</div>
                    <button
                        class="animate-btn"
                        id="animate-btn"
                        onclick="toggleAnimation()"
                    >
                        <svg
                            width="11"
                            height="11"
                            viewBox="0 0 14 14"
                            fill="currentColor"
                        >
                            <path id="play-icon" d="M3,1 L13,7 L3,13 Z"></path>
                        </svg>
                        <span id="animate-label">播放萃取過程</span>
                    </button>
                    <div class="time-display" id="time-display">準備就緒</div>
                </div>

                <div class="panel-section" style="margin-top:4px;">
                    <div class="section-label">機器說明</div>
                    <div class="info-box" id="info-box">
                        <strong>WD 值</strong>（Water Debit）= 機器 10
                        秒的出水克數，反映水流速度與推力。<br /><br />
                        WD 值越高，壓力越快追上粉餅阻力，高壓段維持越久。
                    </div>
                </div>

                <div class="panel-section" style="margin-top:4px;">
                    <div class="concept-box">
                        <div class="concept-title">不同 Pump 的核心邏輯</div>
                        <div class="concept-row">
                            <span class="concept-tag rotary">Rotary</span><span
                                >定壓 9 bar → 粉餅阻力決定<strong
                                    style="color:var(--gold)">實際壓力</strong
                                ></span
                            >
                        </div>
                        <div class="concept-row">
                            <span class="concept-tag vibe">Vibration</span><span
                                >無 OPV 會超過 9 bar → 粉餅阻力決定<strong
                                    style="color:var(--gold)">實際壓力</strong
                                ></span
                            >
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- ===== RIGHT CHART AREA ===== -->
        <div class="chart-area">
            <div id="subtabs-rv">
                <div class="sub-tabs">
                    <div
                        class="sub-tab active"
                        onclick="switchSubTab('pressure', this)"
                    >
                        壓力曲線
                    </div>
                    <div
                        class="sub-tab"
                        onclick="switchSubTab('compare', this)"
                    >
                        手法比較
                    </div>
                    <div
                        class="sub-tab"
                        onclick="switchSubTab('concept', this)"
                    >
                        WD 對照
                    </div>
                </div>

                <div
                    class="tab-content active"
                    id="tab-pressure"
                    style="margin-top:14px;"
                >
                    <div class="chart-header">
                        <div class="chart-title">萃取壓力 vs 時間</div>
                        <div class="legend">
                            <div class="legend-item">
                                <div
                                    class="legend-line"
                                    style="background:#c8a96e;"
                                >
                                </div><span style="color:#c8a96e;"
                                    >假想粉餅阻力</span
                                >
                            </div>
                            <div class="legend-item">
                                <div
                                    class="legend-line"
                                    style="background:#e74c3c;"
                                >
                                </div><span style="color:#e74c3c;"
                                    >實際萃取壓力</span
                                >
                            </div>
                            <div class="legend-item">
                                <div
                                    class="legend-line"
                                    style="background:#3498db; opacity:0.6;"
                                >
                                </div><span style="color:#3498db; opacity:0.7;"
                                    >機器上限</span
                                >
                            </div>
                        </div>
                    </div>
                    <canvas id="pressure-chart" height="230"></canvas>

                    <div
                        class="puck-animation-container"
                        style="margin-top: 10px; background: #1a1a1a; border-radius: 8px; padding: 10px; overflow: hidden;"
                    >
                        <div
                            style="font-size: 10px; color: #888; margin-bottom: 10px; text-transform: uppercase; letter-spacing: 1px;"
                        >
                            Schematic Cross-section (D3 + Canvas)
                        </div>
                        <PuckSimulationD3 client:only="react" />
                    </div>

                    <div class="stats-row">
                        <div class="stat-card">
                            <div class="stat-label">WD 值</div>
                            <div class="stat-value medium" id="stat-wd">80</div>
                            <div class="stat-desc">g / 10s</div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-label">即時壓力</div>
                            <div class="stat-value" id="stat-realtime">0.0</div>
                            <div class="stat-desc">bar</div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-label">峰值壓力</div>
                            <div class="stat-value" id="stat-peak">—</div>
                            <div class="stat-desc">bar</div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-label">高壓維持</div>
                            <div class="stat-value" id="stat-duration">—</div>
                            <div class="stat-desc">秒（>7.5 bar）</div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-label">萃取特性</div>
                            <div class="stat-value" id="stat-character">—</div>
                            <div class="stat-desc" id="stat-note"></div>
                        </div>
                    </div>
                    <div class="narrative" id="narrative-text">
                        請調整左側參數，觀察壓力曲線變化。
                    </div>
                </div>

                <div
                    class="tab-content"
                    id="tab-compare"
                    style="margin-top:14px;"
                >
                    <div class="chart-header">
                        <div class="chart-title">不同手法的假想粉餅阻力</div>
                        <div class="legend">
                            <div class="legend-item">
                                <div
                                    class="legend-line"
                                    style="background:#27ae60;"
                                >
                                </div><span style="color:#27ae60;">重填壓</span>
                            </div>
                            <div class="legend-item">
                                <div
                                    class="legend-line"
                                    style="background:#c8a96e;"
                                >
                                </div><span style="color:#c8a96e;">標準</span>
                            </div>
                            <div class="legend-item">
                                <div
                                    class="legend-line"
                                    style="background:#e74c3c;"
                                >
                                </div><span style="color:#e74c3c;"
                                    >佈粉不均</span
                                >
                            </div>
                        </div>
                    </div>
                    <canvas id="compare-chart" height="230"></canvas>
                    <div class="narrative">
                        <strong>重填壓</strong
                        >：粉餅結構緊密，初期阻力略高（實線 = 假想阻力，虛線 =
                        當前 WD 下實際壓力）。<br /><br />
                        <strong>佈粉不均</strong
                        >：偏流（Channeling）導致阻力提前崩潰。手法差異遠小於 WD
                        值——通常 A/B Test 才能感受風味差異。
                    </div>
                </div>

                <div
                    class="tab-content"
                    id="tab-concept"
                    style="margin-top:14px;"
                >
                    <div class="chart-header">
                        <div class="chart-title">
                            WD 值對照：60 / 80 / 100 g/10s
                        </div>
                        <div class="legend">
                            <div class="legend-item">
                                <div
                                    class="legend-line"
                                    style="background:#3498db;"
                                >
                                </div><span style="color:#3498db;">WD 60</span>
                            </div>
                            <div class="legend-item">
                                <div
                                    class="legend-line"
                                    style="background:#c8a96e;"
                                >
                                </div><span style="color:#c8a96e;">WD 80</span>
                            </div>
                            <div class="legend-item">
                                <div
                                    class="legend-line"
                                    style="background:#e74c3c;"
                                >
                                </div><span style="color:#e74c3c;">WD 100</span>
                            </div>
                        </div>
                    </div>
                    <canvas id="concept-chart" height="270"></canvas>
                    <div class="narrative">
                        三條曲線面對<strong>相同的粉餅阻力</strong>（金色），WD
                        值不同，實際壓力的爬升速度與高壓維持時間截然不同。<br />
                        WD 80 / 標準手法 / Rotary → 峰值 9 bar（基準）。
                    </div>
                </div>
            </div>
        </div>
    </div>

    <Footer />

    <script>
        // 解決 Chart.js 依賴問題
        import Chart from "chart.js/auto";
        (window as any).Chart = Chart;

        import { state } from "../scripts/state.js";
    // Initialize R3F / D3 component if available
    if ((window as any).updatePuckR3F) {
        (window as any).updatePuckR3F(0, (window as any).state);
    }
     import "../scripts/main.js";
    </script>
</Layout>
