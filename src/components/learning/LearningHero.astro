---
/* src/components/learning/LearningHero.astro */
import { useTranslations } from "../../i18n/utils";
const { lang = "zh-TW" } = Astro.props;
const t = useTranslations(lang as any);
---

<section id="hero">
    <div class="hero-bg"></div>
    <div
        class="hero-ring"
        style="width:500px;height:500px;left:50%;top:50%;transform:translate(-50%,-50%)"
    >
    </div>
    <div
        class="hero-ring"
        style="width:750px;height:750px;left:50%;top:50%;transform:translate(-50%,-50%);animation-delay:-2s"
    >
    </div>
    <div
        class="hero-ring"
        style="width:1000px;height:1000px;left:50%;top:50%;transform:translate(-50%,-50%);animation-delay:-4s"
    >
    </div>
    <p class="kicker">{t('learning.hero.kicker')}</p>
    <h1 class="hero-h" id="hero-title" set:html={t('learning.hero.title')}></h1>
    <p class="hero-sub">{t('learning.hero.sub')}</p>
    <div class="scroll-arrow">
        <svg width="24" height="36" viewBox="0 0 24 36" fill="none">
            <line
                x1="12"
                y1="0"
                x2="12"
                y2="28"
                stroke="rgba(184,103,30,0.5)"
                stroke-width="1"></line>
            <polyline
                points="5,20 12,28 19,20"
                fill="none"
                stroke="rgba(184,103,30,0.5)"
                stroke-width="1"></polyline>
        </svg>
    </div>
</section>

<style>
    #hero {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        background: var(--ink);
        position: relative;
        overflow: hidden;
        padding: 5rem 2rem;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
    }

    .hero-bg {
        position: absolute;
        inset: 0;
        background: radial-gradient(
            ellipse 70% 50% at 50% 60%,
            rgba(122, 48, 18, 0.35) 0%,
            transparent 70%
        );
    }

    .hero-ring {
        position: absolute;
        border-radius: 50%;
        border: 1px solid rgba(184, 103, 30, 0.1);
    }

    .kicker {
        font-family: "DM Mono", monospace;
        font-size: 11px;
        letter-spacing: 0.45em;
        color: var(--muted);
        text-transform: uppercase;
        margin-bottom: 2rem;
        opacity: 0;
    }

    .hero-h {
        font-family: "Bebas Neue", sans-serif;
        font-size: clamp(64px, 13vw, 180px);
        line-height: 0.88;
        letter-spacing: 0.04em;
        opacity: 0;
        transform: translateY(40px);
    }

    .hero-h :global(.accent) {
        color: var(--caramel);
    }

    .hero-sub {
        margin-top: 3rem;
        font-size: clamp(14px, 1.5vw, 18px);
        color: var(--muted);
        letter-spacing: 0.2em;
        opacity: 0;
        max-width: 600px;
        line-height: 1.8;
    }

    .scroll-arrow {
        position: absolute;
        bottom: 2.5rem;
        left: 50%;
        transform: translateX(-50%);
        opacity: 0;
    }

    .scroll-arrow svg {
        animation: arrowBounce 2s ease-in-out infinite;
    }

    @keyframes arrowBounce {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(8px); }
    }
</style>
