---
/* src/components/learning/LearningNav.astro */
---

<nav id="nav">
    <div class="dot active" data-target="hero"></div>
    <div class="dot" data-target="s1"></div>
    <div class="dot" data-target="s2"></div>
    <div class="dot" data-target="s3"></div>
    <div class="dot" data-target="s4"></div>
    <div class="dot" data-target="s5"></div>
    <div class="dot" data-target="s6"></div>
    <div class="dot" data-target="s6b"></div>
    <div class="dot" data-target="s7"></div>
    <div class="dot" data-target="s8"></div>
    <div class="dot" data-target="ending"></div>
</nav>

<style>
    #nav {
        position: fixed;
        right: 28px;
        top: 50%;
        transform: translateY(-50%);
        display: flex;
        flex-direction: column;
        gap: 12px;
        z-index: 500;
    }

    .dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: rgba(184, 103, 30, 0.3);
        cursor: pointer;
        transition: all 0.3s;
    }

    :global(.dot.active) {
        background: var(--caramel);
        transform: scale(1.5);
    }
</style>
