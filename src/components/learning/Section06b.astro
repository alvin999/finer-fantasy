---
/* src/components/learning/Section06b.astro */
import LearningSection from "./LearningSection.astro";
---

<LearningSection id="s6b" num="07" tag="Headspace">
    <p slot="text" class="big-text">
        而 <em>Headspace</em> 越大，<br />填滿空間越久<br />等同曲線<b
            >整體右移</b
        >
    </p>
    <div slot="viz" id="viz-headspace">
        <div class="chart-container">
            <p class="chart-title">Headspace 對壓力曲線的影響</p>
            <div class="curve-legend" style="margin-bottom:.8rem">
                <div class="legend-item">
                    <div class="legend-dot" style="background:var(--amber)">
                    </div>小 Headspace
                </div>
                <div class="legend-item">
                    <div
                        class="legend-dot"
                        style="background:rgba(139,115,85,0.65)"
                    >
                    </div>大 Headspace
                </div>
            </div>
            <canvas class="chart-canvas" id="hs-canvas" height="180"></canvas>
            <div
                style="display:flex;justify-content:space-between;margin-top:8px"
            >
                <span class="chart-axis-label">萃取開始</span>
                <span class="chart-axis-label">萃取結束</span>
            </div>
        </div>
        <!-- headspace diagram -->
        <div
            style="margin-top:1.2rem;display:flex;gap:1.5rem;justify-content:center"
        >
            <!-- small headspace -->
            <div style="text-align:center">
                <svg width="90" height="110" viewBox="0 0 90 110">
                    <rect
                        x="10"
                        y="5"
                        width="70"
                        height="18"
                        rx="3"
                        fill="rgba(61,31,13,0.8)"
                        stroke="rgba(184,103,30,0.4)"
                        stroke-width="1"></rect>
                    <text
                        x="45"
                        y="17"
                        text-anchor="middle"
                        font-family="'DM Mono',monospace"
                        font-size="7"
                        fill="var(--muted)">沖煮頭</text
                    >
                    <rect
                        x="18"
                        y="23"
                        width="54"
                        height="6"
                        rx="1"
                        fill="rgba(240,184,74,0.15)"
                        stroke="rgba(240,184,74,0.4)"
                        stroke-width="1"
                        stroke-dasharray="3,2"></rect>
                    <text
                        x="45"
                        y="29"
                        text-anchor="middle"
                        font-family="'DM Mono',monospace"
                        font-size="6"
                        fill="rgba(240,184,74,0.7)">小</text
                    >
                    <rect
                        x="10"
                        y="29"
                        width="70"
                        height="38"
                        rx="2"
                        fill="rgba(90,45,15,0.7)"
                        stroke="rgba(184,103,30,0.3)"
                        stroke-width="1"></rect>
                    <text
                        x="45"
                        y="51"
                        text-anchor="middle"
                        font-family="'DM Mono',monospace"
                        font-size="7"
                        fill="rgba(184,103,30,0.7)">粉餅</text
                    >
                    <rect
                        x="10"
                        y="67"
                        width="70"
                        height="8"
                        rx="1"
                        fill="rgba(61,31,13,0.8)"
                        stroke="rgba(184,103,30,0.3)"
                        stroke-width="1"></rect>
                </svg>
                <p class="hs-label amber">小 Headspace</p>
                <p class="hs-subtext">壓力快速建立</p>
            </div>
            <!-- large headspace -->
            <div style="text-align:center">
                <svg width="90" height="110" viewBox="0 0 90 110">
                    <rect
                        x="10"
                        y="5"
                        width="70"
                        height="18"
                        rx="3"
                        fill="rgba(61,31,13,0.8)"
                        stroke="rgba(184,103,30,0.3)"
                        stroke-width="1"></rect>
                    <text
                        x="45"
                        y="17"
                        text-anchor="middle"
                        font-family="'DM Mono',monospace"
                        font-size="7"
                        fill="var(--muted)">沖煮頭</text
                    >
                    <rect
                        x="18"
                        y="23"
                        width="54"
                        height="20"
                        rx="1"
                        fill="rgba(139,115,85,0.08)"
                        stroke="rgba(139,115,85,0.3)"
                        stroke-width="1"
                        stroke-dasharray="3,2"></rect>
                    <text
                        x="45"
                        y="35"
                        text-anchor="middle"
                        font-family="'DM Mono',monospace"
                        font-size="6"
                        fill="rgba(139,115,85,0.7)">大空間</text
                    >
                    <rect
                        x="10"
                        y="43"
                        width="70"
                        height="28"
                        rx="2"
                        fill="rgba(90,45,15,0.5)"
                        stroke="rgba(139,115,85,0.25)"
                        stroke-width="1"></rect>
                    <text
                        x="45"
                        y="59"
                        text-anchor="middle"
                        font-family="'DM Mono',monospace"
                        font-size="7"
                        fill="rgba(139,115,85,0.6)">粉餅</text
                    >
                    <rect
                        x="10"
                        y="71"
                        width="70"
                        height="8"
                        rx="1"
                        fill="rgba(61,31,13,0.8)"
                        stroke="rgba(184,103,30,0.2)"
                        stroke-width="1"></rect>
                </svg>
                <p class="hs-label">大 Headspace</p>
                <p class="hs-subtext">需先填滿空間</p>
            </div>
        </div>
    </div>
</LearningSection>

<style>
    .curve-legend {
        display: flex;
        gap: 1.5rem;
    }
    .legend-item {
        display: flex;
        align-items: center;
        gap: 8px;
        font-family: "DM Mono", monospace;
        font-size: 10px;
        color: var(--muted);
    }
    .legend-dot {
        width: 24px;
        height: 2px;
    }
    .chart-axis-label {
        font-family: "DM Mono", monospace;
        font-size: 9px;
        color: var(--muted);
        letter-spacing: 0.2em;
    }
    .hs-label {
        font-family: "DM Mono", monospace;
        font-size: 8px;
        color: var(--muted);
        letter-spacing: 0.15em;
        margin-top: 4px;
    }
    .hs-label.amber {
        color: var(--amber);
    }
    .hs-subtext {
        font-family: "DM Mono", monospace;
        font-size: 8px;
        color: var(--muted);
        letter-spacing: 0.1em;
        margin-top: 2px;
    }
</style>
