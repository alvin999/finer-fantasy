---
/* src/components/learning/LearningSection.astro */
interface Props {
    id: string;
    num: string;
    tag: string;
    wide?: boolean;
}
const { id, num, tag, wide = false } = Astro.props;
---

<section id={id}>
    <div class="s-num">{num}</div>
    <div class={`slide-wrap ${wide ? 'wide' : ''}`}>
        <div class="text-col">
            <p class="tag">{tag}</p>
            <div class="line"></div>
            <slot name="text" />
        </div>
        <div class="viz" id={`viz-${id}`}>
            <slot name="viz" />
        </div>
    </div>
</section>

<style>
    section {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 5rem 2rem;
        position: relative;
        overflow: hidden;
    }

    .s-num {
        font-family: "Bebas Neue", sans-serif;
        font-size: clamp(120px, 20vw, 280px);
        line-height: 1;
        color: rgba(184, 103, 30, 0.06);
        position: absolute;
        right: 4vw;
        bottom: -0.1em;
        user-select: none;
        pointer-events: none;
    }

    .slide-wrap {
        max-width: 1100px;
        width: 100%;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 4rem;
        align-items: center;
    }

    .slide-wrap.wide {
        grid-template-columns: 1fr;
        max-width: 1100px;
    }

    .tag {
        font-family: "DM Mono", monospace;
        font-size: 10px;
        letter-spacing: 0.4em;
        color: var(--caramel);
        text-transform: uppercase;
        margin-bottom: 1.2rem;
        opacity: 0;
        transform: translateX(-16px);
    }

    .line {
        width: 48px;
        height: 2px;
        background: var(--caramel);
        margin-bottom: 1.8rem;
        opacity: 0;
        transform: scaleX(0);
        transform-origin: left;
    }

    .viz {
        position: relative;
        opacity: 1;
        transform: none;
    }

    /* 通用文字樣式 */
    :global(.big-text) {
        font-size: clamp(22px, 3.5vw, 46px);
        font-weight: 300;
        line-height: 1.55;
        letter-spacing: 0.03em;
        opacity: 0;
        transform: translateY(24px);
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
    }

    :global(.big-text b) {
        font-weight: 900;
        color: var(--amber);
    }

    :global(.big-text em) {
        font-style: normal;
        color: var(--caramel);
        border-bottom: 1px solid currentColor;
    }

    /* 通用圖表容器 */
    :global(.chart-container) {
        width: 100%;
        background: rgba(61, 31, 13, 0.2);
        border: 1px solid rgba(184, 103, 30, 0.15);
        border-radius: 4px;
        padding: 1.5rem;
    }

    :global(.chart-title) {
        font-family: "DM Mono", monospace;
        font-size: 10px;
        color: var(--muted);
        margin-bottom: 1rem;
    }

    :global(.chart-canvas) {
        width: 100%;
        height: 200px;
    }

    @media (max-width: 700px) {
        .slide-wrap {
            grid-template-columns: 1fr !important;
            gap: 2.5rem;
        }
    }
</style>
