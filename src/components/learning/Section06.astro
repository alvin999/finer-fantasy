---
/* src/components/learning/Section06.astro */
import LearningSection from "./LearningSection.astro";
import { useTranslations } from "../../i18n/utils";
const { lang = "zh-TW" } = Astro.props;
const t = useTranslations(lang as any);
---

<LearningSection id="s6" num="06" tag={t('learning.s6.tag')} wide={true}>
    <p slot="text" class="big-text" set:html={t('learning.s6.text')}></p>
    <div slot="viz" id="viz-wd-bars" style="transform:translateY(20px);margin-top:2rem">
        <div class="wd-wrap">
            <div class="wd-col hi">
                <span class="wd-label">{t('learning.s6.hi')}</span>
                <div class="wd-track">
                    <div class="wd-fill" id="wd-hi-fill"></div>
                </div>
                <p class="wd-desc" set:html={t('learning.s6.hi_desc')}>
                </p>
            </div>
            <div class="wd-col lo">
                <span class="wd-label">{t('learning.s6.lo')}</span>
                <div class="wd-track">
                    <div class="wd-fill" id="wd-lo-fill"></div>
                </div>
                <p class="wd-desc" set:html={t('learning.s6.lo_desc')}>
                </p>
            </div>
        </div>
    </div>
</LearningSection>

<style>
    .wd-wrap {
        display: flex;
        gap: 2rem;
    }
    .wd-col {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 0.8rem;
    }
    .wd-label {
        font-family: "Bebas Neue", sans-serif;
        font-size: 24px;
        color: var(--amber);
    }
    .wd-track {
        height: 180px;
        background: rgba(61, 31, 13, 0.3);
        border: 1px solid rgba(184, 103, 30, 0.15);
        position: relative;
    }
    .wd-fill {
        position: absolute;
        bottom: 0;
        width: 100%;
        background: linear-gradient(to top, var(--rust), var(--amber));
        transform: scaleY(0);
        transform-origin: bottom;
    }
    #wd-hi-fill {
        height: 82%;
    }
    #wd-lo-fill {
        height: 45%;
        background: var(--muted);
    }
    .wd-desc {
        font-size: 0.85rem;
        color: var(--muted);
        line-height: 1.4;
    }
</style>
