---
/* src/components/learning/Section04.astro */
import LearningSection from "./LearningSection.astro";
import { useTranslations } from "../../i18n/utils";
const { lang = "zh-TW" } = Astro.props;
const t = useTranslations(lang as any);
---

<LearningSection id="s4" num="04" tag={t('learning.s4.tag')}>
    <p slot="text" class="big-text" set:html={t('learning.s4.text')}>
    </p>
    <div slot="viz" id="viz-wd-chart">
        <div class="chart-container">
            <p class="chart-title">{t('learning.s4.chart_title')}</p>
            <div class="curve-legend">
                <div class="legend-item">
                    <div
                        class="legend-dot"
                        style="background:rgba(184,103,30,0.4);border-top:1px dashed var(--muted)"
                    >
                    </div>{t('learning.s4.legend_puck')}
                </div>
                <div class="legend-item">
                    <div
                        class="legend-dot"
                        style="background:var(--amber)"
                    >
                    </div>{t('learning.s4.legend_hi')}
                </div>
                <div class="legend-item">
                    <div
                        class="legend-dot"
                        style="background:var(--muted)"
                    >
                    </div>{t('learning.s4.legend_lo')}
                </div>
            </div>
            <canvas class="chart-canvas" id="wd-canvas" height="180"></canvas>
        </div>
    </div>
</LearningSection>

<style>
    .curve-legend {
        display: flex;
        gap: 1.5rem;
        margin-bottom: 0.8rem;
    }
    .legend-item {
        display: flex;
        align-items: center;
        gap: 8px;
        font-family: "DM Mono", monospace;
        font-size: 10px;
        color: var(--muted);
    }
    .legend-dot {
        width: 24px;
        height: 2px;
    }
</style>
