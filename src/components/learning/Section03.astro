---
/* src/components/learning/Section03.astro */
import LearningSection from "./LearningSection.astro";
import { useTranslations } from "../../i18n/utils";
const { lang = "zh-TW" } = Astro.props;
const t = useTranslations(lang as any);
---

<LearningSection id="s3" num="03" tag={t('learning.s3.tag')} wide={true}>
    <div slot="text">
        <p class="big-text" set:html={t('learning.s3.text')}>
        </p>
        <p class="sub-text">
            {t('learning.s3.sub')}
        </p>
    </div>
    <div slot="viz" id="viz-curve" style="margin-top:2.5rem;transform:translateY(20px)">
        <div class="chart-container">
            <p class="chart-title">{t('learning.s3.chart_title')}</p>
            <canvas class="chart-canvas" id="puck-canvas" height="200"></canvas>
            <div style="display:flex;justify-content:space-between;margin-top:8px">
                <span class="chart-axis-label">{t('learning.s3.start')}</span>
                <span class="chart-axis-label">{t('learning.s3.end')}</span>
            </div>
        </div>
    </div>
</LearningSection>

<style>
    .sub-text {
        margin-top: 1rem;
        color: var(--muted);
        font-size: 0.9rem;
        letter-spacing: 0.1em;
        opacity: 0;
        transform: translateY(10px);
    }
    .chart-axis-label {
        font-family: 'DM Mono', monospace;
        font-size: 9px;
        color: var(--muted);
        letter-spacing: 0.2em;
    }
</style>
