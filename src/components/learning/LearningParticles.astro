---
/* src/components/learning/LearningParticles.astro */
---

<canvas id="particles"></canvas>

<style>
    #particles {
        position: fixed;
        inset: 0;
        pointer-events: none;
        z-index: 0;
        opacity: 0.4;
    }
</style>

<script>
    export const initParticles = () => {
        const c = document.getElementById("particles") as HTMLCanvasElement;
        if (!c) return;
        const ctx = c.getContext("2d");
        if (!ctx) return;
        let W: number, H: number, pts: any[] = [];
        
        const resize = () => {
            W = c.width = window.innerWidth;
            H = c.height = window.innerHeight;
        };
        resize();
        window.addEventListener("resize", resize);
        
        for (let i = 0; i < 55; i++) {
            pts.push({
                x: Math.random() * 1920,
                y: Math.random() * 1080,
                vx: (Math.random() - 0.5) * 0.2,
                vy: (Math.random() - 0.5) * 0.15,
                r: Math.random() * 1.5 + 0.3,
                a: Math.random() * 0.4 + 0.05,
            });
        }
        
        const draw = () => {
            ctx.clearRect(0, 0, W, H);
            pts.forEach((p) => {
                p.x += p.vx;
                p.y += p.vy;
                if (p.x < 0) p.x = W;
                if (p.x > W) p.x = 0;
                if (p.y < 0) p.y = H;
                if (p.y > H) p.y = 0;
                ctx.beginPath();
                ctx.arc(p.x % W, p.y % H, p.r, 0, Math.PI * 2);
                ctx.fillStyle = `rgba(184,103,30,${p.a})`;
                ctx.fill();
            });
            requestAnimationFrame(draw);
        };
        draw();
    };

    // Auto-init on client
    initParticles();
</script>
