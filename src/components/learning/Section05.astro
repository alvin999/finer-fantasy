---
/* src/components/learning/Section05.astro */
import LearningSection from "./LearningSection.astro";
---

<LearningSection id="s5" num="05" tag="高壓維持">
    <p slot="text" class="big-text">
        追得越快，<br /><b>高壓維持越久</b><br />風味萃取越完整
    </p>
    <div slot="viz" id="viz-duration">
        <div class="chart-container">
            <p class="chart-title">高壓維持時間比較</p>
            <canvas class="chart-canvas" id="dur-canvas" height="180"></canvas>
            <div class="curve-legend" style="margin-top:10px">
                <div class="legend-item">
                    <div class="legend-dot" style="background:var(--amber)"></div>高 WD
                </div>
                <div class="legend-item">
                    <div class="legend-dot" style="background:var(--muted)"></div>低 WD
                </div>
            </div>
        </div>
    </div>
</LearningSection>

<style>
    .curve-legend {
        display: flex;
        gap: 1.5rem;
    }
    .legend-item {
        display: flex;
        align-items: center;
        gap: 8px;
        font-family: "DM Mono", monospace;
        font-size: 10px;
        color: var(--muted);
    }
    .legend-dot {
        width: 16px;
        height: 2px;
        border-radius: 1px;
    }
</style>
