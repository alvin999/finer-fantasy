---
/* src/components/learning/Section05.astro */
import LearningSection from "./LearningSection.astro";
import { useTranslations } from "../../i18n/utils";
const { lang = "zh-TW" } = Astro.props;
const t = useTranslations(lang as any);
---

<LearningSection id="s5" num="05" tag={t('learning.s5.tag')}>
    <p slot="text" class="big-text" set:html={t('learning.s5.text')}>
    </p>
    <div slot="viz" id="viz-duration">
        <div class="chart-container">
            <p class="chart-title">{t('learning.s5.chart_title')}</p>
            <canvas class="chart-canvas" id="dur-canvas" height="180"></canvas>
            <div class="curve-legend" style="margin-top:10px">
                <div class="legend-item">
                    <div class="legend-dot" style="background:var(--amber)"></div>{t('learning.s4.legend_hi')}
                </div>
                <div class="legend-item">
                    <div class="legend-dot" style="background:var(--muted)"></div>{t('learning.s4.legend_lo')}
                </div>
            </div>
        </div>
    </div>
</LearningSection>

<style>
    .curve-legend {
        display: flex;
        gap: 1.5rem;
    }
    .legend-item {
        display: flex;
        align-items: center;
        gap: 8px;
        font-family: "DM Mono", monospace;
        font-size: 10px;
        color: var(--muted);
    }
    .legend-dot {
        width: 16px;
        height: 2px;
        border-radius: 1px;
    }
</style>
