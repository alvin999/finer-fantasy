---
/* src/components/learning/Section07.astro */
import LearningSection from "./LearningSection.astro";
import { useTranslations } from "../../i18n/utils";
const { lang = "zh-TW" } = Astro.props;
const t = useTranslations(lang as any);
---

<LearningSection id="s7" num="08" tag={t('learning.s7.tag')}>
    <p slot="text" class="big-text" set:html={t('learning.s7.text')}>
    </p>
    <div slot="viz" id="viz-tamp">
        <svg
            width="220"
            height="200"
            viewBox="0 0 220 200"
            style="display:block;margin:auto"
        >
            <text x="60" y="18" text-anchor="middle" font-family="'DM Mono',monospace" font-size="9" fill="var(--caramel)" letter-spacing="1">{t('learning.s7.heavy')}</text>
            <rect x="20" y="25" width="80" height="50" rx="3" fill="rgba(61,31,13,0.5)" stroke="rgba(184,103,30,0.3)" stroke-width="1"></rect>
            <!-- dense dots -->
            <g id="dense-dots" fill="rgba(184,103,30,0.6)">
                <circle cx="35" cy="40" r="2.5"></circle>
                <circle cx="50" cy="35" r="2.5"></circle>
                <circle cx="65" cy="40" r="2.5"></circle>
                <circle cx="80" cy="35" r="2.5"></circle>
                <circle cx="35" cy="55" r="2.5"></circle>
                <circle cx="50" cy="60" r="2.5"></circle>
                <circle cx="65" cy="55" r="2.5"></circle>
                <circle cx="80" cy="60" r="2.5"></circle>
                <circle cx="42" cy="47" r="2.5"></circle>
                <circle cx="72" cy="47" r="2.5"></circle>
                <circle cx="57" cy="48" r="2.5"></circle>
            </g>
            <text x="60" y="92" text-anchor="middle" font-family="'DM Mono',monospace" font-size="8" fill="var(--muted)" letter-spacing="1">{t('learning.s7.stable')}</text>

            <text x="160" y="18" text-anchor="middle" font-family="'DM Mono',monospace" font-size="9" fill="var(--muted)" letter-spacing="1">{t('learning.s7.light')}</text>
            <rect x="120" y="25" width="80" height="50" rx="3" fill="rgba(61,31,13,0.3)" stroke="rgba(139,115,85,0.2)" stroke-width="1"></rect>
            <!-- loose dots -->
            <g fill="rgba(139,115,85,0.4)">
                <circle cx="135" cy="36" r="2.5"></circle>
                <circle cx="155" cy="44" r="2.5"></circle>
                <circle cx="170" cy="32" r="2.5"></circle>
                <circle cx="185" cy="48" r="2.5"></circle>
                <circle cx="140" cy="60" r="2.5"></circle>
                <circle cx="162" cy="66" r="2.5"></circle>
                <circle cx="178" cy="58" r="2.5"></circle>
            </g>
            <text x="160" y="92" text-anchor="middle" font-family="'DM Mono',monospace" font-size="8" fill="var(--muted)" letter-spacing="1">{t('learning.s7.loose')}</text>

            <line x1="10" y1="110" x2="210" y2="110" stroke="rgba(184,103,30,0.1)" stroke-width="1"></line>
            <path id="tamp-h-curve" d="M 20,180 C 50,145 80,125 100,115 S 150,115 200,125" fill="none" stroke="var(--amber)" stroke-width="2" stroke-dasharray="200" stroke-dashoffset="200"></path>
            <path id="tamp-l-curve" d="M 20,190 C 50,170 80,155 100,145 S 150,140 200,145" fill="none" stroke="rgba(139,115,85,0.5)" stroke-width="1.5" stroke-dasharray="200" stroke-dashoffset="200"></path>
            <text x="110" y="200" text-anchor="middle" font-family="'DM Mono',monospace" font-size="8" fill="rgba(184,103,30,0.5)" letter-spacing="1">{t('learning.s7.puck_curve')}</text>
        </svg>
    </div>
</LearningSection>
