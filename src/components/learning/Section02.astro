---
/* src/components/learning/Section02.astro */
import LearningSection from "./LearningSection.astro";
---

<LearningSection id="s2" num="02" tag="動態變化">
    <p slot="text" class="big-text">
        熱水穿透咖啡粉，<br />阻力<b>持續下降</b><br />壓力隨之改變
    </p>
    <div slot="viz" id="viz-flow">
        <svg
            width="220"
            height="260"
            viewBox="0 0 220 260"
            style="display:block;margin:auto"
        >
            <!-- portafilter basket -->
            <rect
                x="30"
                y="10"
                width="160"
                height="120"
                rx="4"
                fill="rgba(61,31,13,0.6)"
                stroke="rgba(184,103,30,0.3)"
                stroke-width="1"></rect>
            <!-- puck -->
            <rect
                id="puck-rect"
                x="35"
                y="20"
                width="150"
                height="100"
                rx="2"
                fill="rgba(90,45,15,0.8)"
                stroke="rgba(184,103,30,0.2)"
                stroke-width="1"></rect>
            <!-- water droplets falling -->
            <circle
                class="wdrop"
                cx="80"
                cy="15"
                r="3"
                fill="rgba(180,200,255,0.6)"></circle>
            <circle
                class="wdrop"
                cx="110"
                cy="8"
                r="3"
                fill="rgba(180,200,255,0.6)"></circle>
            <circle
                class="wdrop"
                cx="145"
                cy="12"
                r="3"
                fill="rgba(180,200,255,0.6)"></circle>
            <!-- resistance arrows -->
            <g id="resist-arrows">
                <line
                    x1="110"
                    y1="70"
                    x2="110"
                    y2="30"
                    stroke="rgba(212,149,42,0.7)"
                    stroke-width="1.5"
                    marker-end="url(#arr)"></line>
                <line
                    x1="80"
                    y1="70"
                    x2="80"
                    y2="30"
                    stroke="rgba(212,149,42,0.5)"
                    stroke-width="1"></line>
                <line
                    x1="140"
                    y1="70"
                    x2="140"
                    y2="30"
                    stroke="rgba(212,149,42,0.5)"
                    stroke-width="1"></line>
            </g>
            <defs>
                <marker
                    id="arr"
                    markerWidth="6"
                    markerHeight="6"
                    refX="3"
                    refY="3"
                    orient="auto"
                >
                    <path
                        d="M0,0 L6,3 L0,6 Z"
                        fill="rgba(212,149,42,0.8)"></path>
                </marker>
            </defs>
            <!-- spouts bottom -->
            <rect
                x="30"
                y="130"
                width="160"
                height="10"
                rx="2"
                fill="rgba(61,31,13,0.8)"
                stroke="rgba(184,103,30,0.2)"
                stroke-width="1"></rect>
            <!-- coffee drips -->
            <line
                class="cdrip"
                x1="70"
                y1="140"
                x2="70"
                y2="160"
                stroke="rgba(180,100,20,0.7)"
                stroke-width="2"></line>
            <line
                class="cdrip"
                x1="110"
                y1="140"
                x2="110"
                y2="165"
                stroke="rgba(180,100,20,0.7)"
                stroke-width="2"></line>
            <line
                class="cdrip"
                x1="150"
                y1="140"
                x2="150"
                y2="158"
                stroke="rgba(180,100,20,0.7)"
                stroke-width="2"></line>
            <!-- cup -->
            <path
                d="M50,200 L55,250 L165,250 L170,200 Z"
                fill="rgba(61,31,13,0.7)"
                stroke="rgba(184,103,30,0.25)"
                stroke-width="1"></path>
            <!-- coffee level -->
            <rect
                id="cup-fill"
                x="55"
                y="235"
                width="110"
                height="15"
                fill="rgba(122,48,18,0.6)"
                rx="1"></rect>
            <!-- resistance text -->
            <text
                x="110"
                y="185"
                text-anchor="middle"
                font-family="'DM Mono',monospace"
                font-size="9"
                fill="rgba(184,103,30,0.7)"
                letter-spacing="2">RESISTANCE ↓</text
            >
        </svg>
    </div>
</LearningSection>

<style is:global>
    /* Section 專屬樣式（如果有的話） */
</style>
